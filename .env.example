# TestPilotBot Environment Configuration
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to source control.

# Default test environment URL (used when no --test-env is passed)
TEST_ENV_URL=

# Admin panel URL for approving test users
ADMIN_URL=

# Admin login email (password is NOT stored here — enter it manually or use a credential manager)
ADMIN_EMAIL=

# Path to QA team's business rules directory
# Default: /Users/khantopa/dev/sa-ui-automation/.cursor/business-rules
QA_BUSINESS_RULES_PATH=/Users/khantopa/dev/sa-ui-automation/.cursor/business-rules
